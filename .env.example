# --- Runtime ---
PORT=3000
NODE_ENV=production

# --- Supabase (server-side only; NEVER expose service key to the browser) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...
SUPABASE_STATE_ID=main
SUPABASE_KEEP_HISTORY=true

# --- Brevo SMTP (defaults; the Settings module can override at runtime) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-brevo-login@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM_NAME=Montesierra Dormitory
SMTP_FROM_EMAIL=noreply@yourdomain.com

# --- CORS (comma-separated; empty = allow all) ---
CORS_ORIGINS=
